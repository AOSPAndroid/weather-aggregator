PORT=3000

# API keys (optional — system works without them via scrapers/Open-Meteo)
MET_OFFICE_API_KEY=
METEO_FRANCE_API_KEY=
WU_API_KEY=

# Source toggles
ENABLE_OPEN_METEO=true
ENABLE_NWS=true
ENABLE_MET_OFFICE=true
ENABLE_METEO_FRANCE=true
ENABLE_WUNDERGROUND=true
ENABLE_IEM=true
ENABLE_METAR=true

# Scraper toggle
ENABLE_SCRAPERS=true

# Reliability
FETCH_TIMEOUT_MS=9000
MAX_RETRIES=1
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RESET_MS=300000

# Scraping politeness
SCRAPE_INTERVAL_MS=720000
SCRAPE_JITTER_PCT=30
SCRAPE_BACKOFF_INITIAL_MS=1800000
SCRAPE_BACKOFF_MAX_MS=3600000
SCRAPE_DAILY_CAP=100

# Risk gates
MIN_INDEPENDENT_SOURCES=2
MAX_SPREAD_C=5
MAX_ANCHOR_STALE_MINUTES=120
REJECT_SCRAPER_ONLY=true

# Confidence thresholds
ANCHOR_CONFLICT_THRESHOLD_C=2
HIGH_CONFIDENCE_MIN_SOURCES=3
